        "import cv2\n",
        "import numpy as np\n",
        "import mtcnn\n",
        "from keras.models import load_model\n",
        "from keras_facenet import FaceNet\n",
        "\n",
        "from sklearn.preprocessing import Normalizer\n",
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "import serial\n",
        "import time\n",
        "\n",
        "\n",
        "#------------ PUENTE PYTHON ARDUINIO----------------------------------------------\n",
        "#Estalbelce la comunicacion de python a arduino\n",
        "arduino = serial.Serial(port='COM3', baudrate=115200, timeout=.1)\n",
        "\n",
        "\n",
        "#Carga el modelo de FaceNet que nos permitira obtner los vectores de las caras\n",
        "embedder = FaceNet()\n",
        "\n",
        "\n",
        "\n",
        "#se declara el filtro de casacada detecta caras unicamente\n",
        "face_cascade = cv2.CascadeClassifier(\n",
        "    cv2.data.haarcascades + 'haarcascade_frontalface_default.xml'\n",
        ")\n",
        "\n",
        "#------------ GET EMBEDING ----------------------------------------------\n",
        "#funcion para obtenre el vector de una cara\n",
        "def get_embedding(face):\n",
        "    face_rgb = cv2.cvtColor(face, cv2.COLOR_BGR2RGB)\n",
        "    face_resized = cv2.resize(face_rgb, (160, 160))\n",
        "    return embedder.embeddings([face_resized])[0]\n",
        "\n",
        "#------------ RECOGNIZE FUNCTION ----------------------------------------------\n",
        "#funcion para reconocer si la imagen caturada es similar a la imagen o imagenes guardadas\n",
        "#como vectores en los sistemas\n",
        "def recognize(embedding, known_db, threshold=0.3):\n",
        "\n",
        "    best_name, best_score = \"Unknown\", -1\n",
        "    for name, known_emb in known_db.items():\n",
        "\n",
        "        #calcula el score comparando el vector de la cara conocida con el vector de la cara detectada\n",
        "        score = np.dot(embedding, known_emb) / (np.linalg.norm(embedding) * np.linalg.norm(known_emb))\n",
        "\n",
        "        score = abs(score)\n",
        "\n",
        "        #si pasa cierto simite lo acpeta y marca el score y el nombre\n",
        "        #si no lo marca como Unknown\n",
        "        if score > best_score:\n",
        "            best_score = score\n",
        "            best_name = name if score >= threshold else \"Unknown\"\n",
        "    return best_name, best_score\n",
        "\n",
        "\n",
        "\n",
        "#------------ ENROLL FUNCTION ----------------------------------------------\n",
        "#funcion para convertir la imagen de una cara en un vector\n",
        "#a diferencia de la funcion get_embeding esta procesa la imagen\n",
        "def enroll(image_path, name, known_db):\n",
        "    img = cv2.imread(image_path)\n",
        "    if img is None:\n",
        "        print(f\"❌ Could not read: {image_path}\")\n",
        "        return\n",
        "    known_db[name] = get_embedding(img)\n",
        "    print(f\"✅ Enrolled: {name}\")\n",
        "\n",
        "#------------ Actuadores FUNCTION ----------------------------------------------\n",
        "#Actuadores\n",
        "#funcion para dar input a los actuadores\n",
        "def write_read(x):\n",
        "\t#this writes data to arduino\n",
        "\tarduino.write(bytes(x, 'utf-8'))\n",
        "\ttime.sleep(0.05)\n",
        "\n",
        "\n",
        "\n",
        "# ── Enroll faces ──────────────────────────────────────────────\n",
        "known_db = {}\n",
        "\n",
        "\n",
        "enroll('pictures/Henry.jpg','Henry',known_db)\n",
        "\n",
        "\n",
        "\n",
        "# ── CICLO PRINCIPAL ─────────────────────────────────────────────────\n",
        "#empiza la captura de la camara y lo guarda en una var\n",
        "cap = cv2.VideoCapture(0)\n",
        "\n",
        "\n",
        "#este ciclo es donde se van a analizar las imagenes del video para obtener\n",
        "#los datos de si detecta la cara que se establecio\n",
        "\n",
        "while True:\n",
        "    ret, frame = cap.read()\n",
        "    if not ret:\n",
        "        break\n",
        "\n",
        "    #aqui el filtro obtinene las capuras de las cara y los guarda en faces\n",
        "    #como corrdenadas donde se detecta la cara\n",
        "    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n",
        "    faces = face_cascade.detectMultiScale(\n",
        "        gray, scaleFactor=1.1, minNeighbors=5, minSize=(80, 80)\n",
        "    )\n",
        "\n",
        "\n",
        "    #aqui se obtiene el vector de las caras capturadas\n",
        "    #y se obtiene un score de similitud con la imagen guardada\n",
        "    #y a su vez el nombre\n",
        "    for (x, y, w, h) in faces:\n",
        "        face_crop = frame[y:y+h, x:x+w]\n",
        "\n",
        "        try:\n",
        "            embedding = get_embedding(face_crop)\n",
        "            name, score = recognize(embedding, known_db)\n",
        "        except Exception as e:\n",
        "            name, score = \"Error\", 0.0\n",
        "\n",
        "\n",
        "        #aqui establece el color del cuadro de la cara\n",
        "        #rojo si es desconocido y verde si es detectado\n",
        "        color = (0, 255, 0) if name != \"Unknown\" else (0, 0, 255)\n",
        "\n",
        "\n",
        "        #------------------------------------------- logica arduino-----\n",
        "\n",
        "        #manda valor al ardunio si detecta correctamente\n",
        "        if name != 'Unknown':\n",
        "            value = write_read(str(1))\n",
        "\n",
        "\n",
        "\n",
        "        #------------------------------------------- logica arduino-----\n",
        "\n",
        "        #Marca cuadros de las caras\n",
        "        cv2.rectangle(frame, (x, y), (x+w, y+h), color, 2)\n",
        "        cv2.putText(frame, f\"{name} ({score:.2f})\",\n",
        "                    (x, y - 10), cv2.FONT_HERSHEY_SIMPLEX,\n",
        "                    0.65, color, 2)\n",
        "\n",
        "    #Muestra las capturas y epera a cerrar\n",
        "    cv2.imshow(\"FaceNet Live\", frame)\n",
        "    if cv2.waitKey(1) & 0xFF == ord('q'):\n",
        "        break\n",
        "\n",
        "cap.release()\n",
        "cv2.destroyAllWindows()"
